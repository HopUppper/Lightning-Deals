{
  "version": 2,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://checkout.razorpay.com https://challenges.cloudflare.com https://www.googletagmanager.com https://www.google-analytics.com https://unpkg.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; connect-src 'self' https://lightning-deals-d0adc-default-rtdb.asia-southeast1.firebasedatabase.app https://api.razorpay.com https://challenges.cloudflare.com https://www.google-analytics.com https://*.googleapis.com https://*.firebaseapp.com; frame-src 'self' https://checkout.razorpay.com https://challenges.cloudflare.com https://*.firebaseapp.com; img-src 'self' data: https://checkout.razorpay.com https://www.google-analytics.com https://unpkg.com https://cdnjs.cloudflare.com; frame-ancestors 'none';"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), gyroscope=(), magnetometer=(), payment=(*), fullscreen=(*)"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/admin",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/admin.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/.netlify/functions/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/api/create-order.php",
      "destination": "/api/create-order"
    },
    {
      "source": "/api/verify-payment.php",
      "destination": "/api/verify-payment"
    },
    {
      "source": "/api/razorpay-webhook.php",
      "destination": "/api/razorpay-webhook"
    },
    {
      "source": "/api/verify-admin.php",
      "destination": "/api/admin-auth?action=verify-admin"
    },
    {
      "source": "/api/verify-admin",
      "destination": "/api/admin-auth?action=verify-admin"
    },
    {
      "source": "/api/admin-setup-2fa",
      "destination": "/api/admin-auth?action=setup-2fa"
    },
    {
      "source": "/api/admin-verify-2fa",
      "destination": "/api/admin-auth?action=verify-2fa"
    },
    {
      "source": "/api/admin-login-2fa",
      "destination": "/api/admin-auth?action=login-2fa"
    },
    {
      "source": "/api/admin-logout",
      "destination": "/api/admin-auth?action=logout"
    },
    {
      "source": "/api/auth-signup",
      "destination": "/api/auth?action=signup"
    },
    {
      "source": "/api/auth-login",
      "destination": "/api/auth?action=login"
    },
    {
      "source": "/api/auth-session",
      "destination": "/api/auth?action=session"
    },
    {
      "source": "/api/auth-reset",
      "destination": "/api/auth?action=reset"
    }
  ]
}